<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS web.config สำหรับ QTEC Knowledge Brain
  วางไฟล์นี้ที่ root folder ของ IIS site (C:\inetpub\wwwroot\brain\)

  ต้องติดตั้ง:
  - IIS: Application Request Routing (ARR)
  - IIS: URL Rewrite Module 2.x
  - Windows Authentication feature
-->
<configuration>
  <system.webServer>

    <!-- ── Windows Authentication ── -->
    <security>
      <authentication>
        <anonymousAuthentication enabled="false" />
        <windowsAuthentication enabled="true" />
      </authentication>
    </security>

    <!-- ── Reverse Proxy to Docker container (port 8080) ── -->
    <rewrite>
      <rules>
        <rule name="ReverseProxyToNode" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:8080/{R:1}" />
          <serverVariables>
            <!-- ส่ง Windows Auth identity ไปให้ Next.js -->
            <set name="HTTP_X_IIS_AUTH_USER"
                 value="{C:1}" />
            <set name="HTTP_X_IIS_AUTH_DISPLAYNAME"
                 value="{HTTP_AUTH_USER}" />
          </serverVariables>
        </rule>
      </rules>
    </rewrite>

    <!-- ── Forward Windows Auth headers ── -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>

  </system.webServer>
</configuration>
