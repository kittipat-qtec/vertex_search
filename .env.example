# === App ===
NEXT_PUBLIC_APP_NAME=QTEC Knowledge Brain
MOCK_MODE=true

# === Google Cloud ===
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# === Vertex AI Search ===
DATA_STORE_ID=your-data-store-id
DATA_STORE_LOCATION=global
DATA_STORE_COLLECTION=default_collection

# === Model ===
MODEL_NAME=gemini-2.5-flash

# === Auth Headers ===
AUTH_HEADER_USER=x-iis-auth-user
AUTH_HEADER_DISPLAYNAME=x-iis-auth-displayname
AUTH_HEADER_EMAIL=x-iis-auth-email
AUTH_HEADER_DOMAIN=x-iis-auth-domain

# === Mock Auth ===
MOCK_AUTH_USER=YOURDOMAIN\example.user
MOCK_AUTH_DISPLAYNAME=Example User
MOCK_AUTH_EMAIL=user@example.com

# === Admin Access ===
ADMIN_USERS=admin@example.com
